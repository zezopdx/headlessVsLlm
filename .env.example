# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Snowflake
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PRIVATE_KEY_FILE=snowflake_rsa_key.p8   # local: path to .p8 file
SNOWFLAKE_PRIVATE_KEY_B64=                         # Heroku: base64-encoded .p8 contents (heroku config:set SNOWFLAKE_PRIVATE_KEY_B64="$(base64 -i snowflake_rsa_key.p8)")
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_ROLE=your_role
# No default database/schema — queries use fully qualified names (DB.SCHEMA.TABLE)
